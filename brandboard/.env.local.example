# Brandboard AI — environment variables
# Copy to .env.local and fill in values from your Supabase project settings.

# Supabase (required for database + auth)
# Use the project URL, NOT the REST endpoint:
#   ✓ https://your-project.supabase.co
#   ✗ https://your-project.supabase.co/rest/v1
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (required for brand audit pipeline)
OPENAI_API_KEY=

# Local dev: synchronous mock audits — skips after(), Brandfetch, and OpenAI
AUDIT_DEBUG_FAST=false

# Brandfetch (required for brand asset enrichment when AUDIT_DEBUG_FAST=false)
BRANDFETCH_API_KEY=
# Optional: improves company-name → domain resolution via Brand Search API
BRANDFETCH_CLIENT_ID=
SERPAPI_API_KEY=
APIFY_TOKEN=
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
